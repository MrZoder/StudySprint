# -----------------------------------------------------------------------------
# StudySprint — AI Planner configuration
# -----------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in the values you want to use.
# `.env.local` is gitignored by default — never commit real API keys.
#
# The AI Planner is designed to work without any keys set: with no
# OPENAI_API_KEY it automatically falls back to the on-device heuristic
# planner so the feature remains fully functional in development.
#
# When a key is present, the server-side /api/ai-planner/analyze endpoint
# calls the LLM provider, the UI surfaces "LLM-assisted plan" in the output,
# and the validation layer still runs against every response.

# -- OpenAI ---------------------------------------------------------------

# Your OpenAI API key. Required when AI_PLANNER_PROVIDER is "openai" (or "auto"
# and you want LLM-powered plans). Leave blank to force the heuristic fallback.
OPENAI_API_KEY=

# Model override. The planner is tuned for OpenAI's structured-output models.
# Recommended: gpt-4o-mini (cheap, fast, good structured-output reliability)
# Alternative: gpt-4o, gpt-4.1-mini, gpt-4.1
OPENAI_PLANNER_MODEL=gpt-4o-mini

# Optional base URL override for Azure OpenAI, LiteLLM, or other OpenAI-
# compatible proxies. Leave blank to use api.openai.com directly.
OPENAI_BASE_URL=

# -- Provider selection ---------------------------------------------------

# Which provider the /api/ai-planner/analyze endpoint should use.
#   auto       → OpenAI when OPENAI_API_KEY is set, heuristic otherwise (default)
#   openai     → force OpenAI (errors out if no key is set)
#   heuristic  → force the deterministic on-device fallback (no network calls)
AI_PLANNER_PROVIDER=auto
